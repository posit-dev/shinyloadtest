{
  "name": "@posit-dev/shinyloadtest",
  "version": "2.0.0-alpha.2",
  "description": "Load testing tool for Shiny applications",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "shinyloadtest": "dist/main.js",
    "shinycannon": "dist/shinycannon.js"
  },
  "scripts": {
    "build": "npm run build:report && tsup",
    "build:report": "vite build --config src/report/app/vite.config.ts",
    "dev": "tsx src/main.ts",
    "dev:report": "vite dev --config src/report/app/vite.config.ts",
    "dev:report:demo1": "REPORT_DEV_DIR=fixture:demo1 vite dev --config src/report/app/vite.config.ts",
    "dev:report:demo4": "REPORT_DEV_DIR=fixture:demo4 vite dev --config src/report/app/vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --list-different --write src/",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "pre-push": "npx prettier --check src/ && npm run lint && npm run typecheck"
  },
  "pre-push": [
    "pre-push"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/posit-dev/shinyloadtest.git"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "commander": "^13.1.0",
    "d3": "^7.9.0",
    "ora": "^9.3.0",
    "tough-cookie": "^5.1.2",
    "ws": "^8.18.1",
    "yoctocolors": "^2.1.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^20.17.24",
    "@types/tough-cookie": "^4.0.5",
    "@types/ws": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.21.0",
    "happy-dom": "^20.8.4",
    "pre-push": "^0.1.4",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.9"
  }
}
